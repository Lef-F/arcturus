{
  "name": "arcturus",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Browser-based virtual analog synthesizer with Arturia hardware integration",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "vitest run src/test/e2e.test.ts",
    "test:coverage": "vitest run --coverage"
  },
  "packageManager": "pnpm@10.18.0",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.2.2",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^10.1.0",
    "fake-indexeddb": "^6.2.5",
    "globals": "^17.4.0",
    "happy-dom": "^20.8.4",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "vite": "^8.0.1",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "@grame/faustwasm": "^0.15.7",
    "idb": "^8.0.3"
  }
}
